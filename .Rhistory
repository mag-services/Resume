full_data <- read.csv("data/1c_input_baseline.csv")
# Standardize Area Council names
full_data <- full_data %>%
mutate(
"Area Council" = recode(
"Area Council",
"Central malekula"      = "Central Malekula",
"Central pentecost 2"   = "Central Pentecost 2",
"East santo"            = "East Santo",
"luganville"            = "Luganville",
"North West malekula"   = "North West Malekula",
"pentecost"             = "Pentecost",
"West gaua"             = "West Gaua"
)
)
