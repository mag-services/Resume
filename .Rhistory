# Force Value to numeric EARLY (before pivot)
Value = as.numeric(Value),   # NA introduced where conversion fails
education_level = tolower(Attribute),
measure_type = case_when(
grepl("Number Schools|Nb of Schools|schools", Indicator, ignore.case = TRUE) ~ "schools",
grepl("Students|Nb Students|enrolment",       Indicator, ignore.case = TRUE) ~ "students",
grepl("Teachers|Nb Teachers|staff",           Indicator, ignore.case = TRUE) ~ "teachers",
TRUE ~ "other"
)
) %>%
filter(measure_type %in% c("schools", "students", "teachers")) %>%
select(Region, education_level, measure_type, Value) %>%
pivot_wider(
names_from  = c(education_level, measure_type),
values_from = Value,
names_sep   = "_",
values_fill = 0
) %>%
# Optional: replace any remaining NA with 0
mutate(across(where(is.numeric), ~replace_na(.x, 0)))
# === DATA WRANGLING ===
# Filter for Education in Baseline column and Area Council level data
education_data <- full_data %>%
filter(Baseline == "Education") %>%  # Changed to filter Baseline column
filter(Year == max(Year, na.rm = TRUE)) %>%  # Filter for the latest year
filter(!is.na("Area Council")) %>%
mutate(Region = "Area Council")
# Reshape the data to get Schools, Students, Teachers as separate columns
education_wide <- education_data %>%
mutate(
# Force Value to numeric EARLY (before pivot)
Value = as.numeric(Value),   # NA introduced where conversion fails
education_level = tolower(Attribute),
measure_type = case_when(
grepl("Number Schools|Nb of Schools|schools", Indicator, ignore.case = TRUE) ~ "schools",
grepl("Students|Nb Students|enrolment",       Indicator, ignore.case = TRUE) ~ "students",
grepl("Teachers|Nb Teachers|staff",           Indicator, ignore.case = TRUE) ~ "teachers",
TRUE ~ "other"
)
) %>%
filter(measure_type %in% c("schools", "students", "teachers")) %>%
select(Region, education_level, measure_type, Value) %>%
pivot_wider(
names_from  = c(education_level, measure_type),
values_from = Value,
names_sep   = "_",
values_fill = list(0)
) %>%
# Optional: replace any remaining NA with 0
mutate(across(where(is.numeric), ~replace_na(.x, 0)))
# Add total columns
education_wide <- education_wide %>%
mutate(
total_schools = ecce_schools + primary_schools + secondary_schools,
total_students = ecce_students + primary_students + secondary_students,
total_teachers = ecce_teachers + primary_teachers + secondary_teachers
) %>%
select(Region, total_schools, total_students, total_teachers, everything())
# === DATA WRANGLING ===
# Filter for Education in Baseline column and Area Council level data
education_wide <- education_data %>%
# Step 1: Clean and force numeric EARLY – replace bad values with 0
mutate(
Value_clean = suppressWarnings(as.numeric(trimws(Value))),  # trim spaces, suppress warnings
Value_clean = ifelse(is.na(Value_clean), 0, Value_clean)   # failed conversions → 0
) %>%
# Step 2: Create level and measure (use cleaned value)
mutate(
education_level = tolower(Attribute),
measure_type = case_when(
grepl("Number Schools|Nb of Schools|schools", Indicator, ignore.case = TRUE) ~ "schools",
grepl("Students|Nb Students|enrolment",       Indicator, ignore.case = TRUE) ~ "students",
grepl("Teachers|Nb Teachers|staff",           Indicator, ignore.case = TRUE) ~ "teachers",
TRUE ~ "other"
)
) %>%
# Step 3: Filter only valid measures
filter(measure_type %in% c("schools", "students", "teachers")) %>%
# Step 4: Pivot with clean numeric values
select(Region, education_level, measure_type, Value_clean) %>%
pivot_wider(
names_from  = c(education_level, measure_type),
values_from = Value_clean,
names_sep   = "_",
values_fill = list(0)   # safe fill for missing combinations
) %>%
# Step 5: Final safety net – ensure all value columns are numeric
mutate(across(-Region, ~as.numeric(.x))) %>%          # force numeric (just in case)
mutate(across(-Region, ~replace_na(.x, 0)))           # any remaining NA → 0
